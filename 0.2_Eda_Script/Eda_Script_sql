-- ============================================================
-- 2. FACT TABLE
-- ============================================================

-- ------------------------------------------------------------
-- 2.1 FACT_SALES
-- ------------------------------------------------------------

CREATE OR REPLACE TABLE FACT_SALES (
Order_ID STRING,
Store_ID STRING,
Customer_ID STRING,
Salesperson_ID STRING,
Product_ID STRING,
Promotion_ID STRING,
Returned STRING,
Quantity STRING,
Unit_Cost STRING,
Unit_Price STRING,
Discount_Amount STRING,
Tax_Amount STRING,
Shipping_Cost STRING,
Gross_Sales STRING,
Net_Sales STRING,
COGS STRING,
Gross_Profit STRING
);
SELECT * FROM FACT_SALES;

INSERT INTO FACT_SALES
SELECT
`Order ID`,
`Store ID`,
`Customer ID`,
`Salesperson ID`,
`Product ID`,
`Promotion ID`,
Returned,
CAST(Quantity AS STRING),
CAST(`Unit Cost` AS STRING),
CAST(`Unit Price` AS STRING),
CAST(`Discount Amount` AS STRING),
CAST(`Tax Amount` AS STRING),
CAST(`Shipping Cost` AS STRING),
CAST(`Gross Sales` AS STRING),
CAST(`Net Sales` AS STRING),
CAST(COGS AS STRING),
CAST(`Gross Profit` AS STRING)
FROM retail_sales_data;