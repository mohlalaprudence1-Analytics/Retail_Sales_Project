-- ============================================================
-- 2. FACT TABLE
-- ============================================================

-- ------------------------------------------------------------
-- 2.1 FACT_SALES
-- ------------------------------------------------------------
    DROP TABLE IF EXISTS FACT_SALES;
    CREATE TABLE FACT_SALES (
    Order_ID STRING,
    Store_ID STRING,
    Customer_ID STRING,
    Salesperson_ID STRING,
    Product_ID STRING,
    Promotion_ID STRING,
    Returned STRING,
    Quantity INT,
    Unit_Cost INT,
    Unit_Price INT,
    Discount_Amount INT,
    Tax_Amount INT,
    Shipping_Cost INT,
    Gross_Sales INT,
    Net_Sales INT,
    COGS INT,
    Gross_Profit INT
);

INSERT INTO fact_sales
SELECT
`Order ID`,
`Store ID`,
`Customer ID`,
`Salesperson ID`,
`Product ID`,
`Promotion ID`,
Returned,
CAST(Quantity AS INT),
CAST(`Unit Cost` AS INT),
CAST(`Unit Price` AS INT),
CAST(`Discount Amount` AS INT),
CAST(`Tax Amount` AS INT),
CAST(`Shipping Cost` AS INT),
CAST(`Gross Sales` AS INT),
CAST(`Net Sales` AS INT),
CAST(COGS AS INT),
CAST(`Gross Profit` AS INT)
FROM retail_sales_data;
